  "info": {
    "_postman_id": "830fa50b-b54e-4b4d-bb0c-3f146c2da2c2",
    "name": "Efí Pay Pagamentos (Bill Payment) API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Brazilian bill-payment automation for Efí Pay. Decode a boleto/concessionária barcode (linha digitável), submit it for payment from the account balance, and reconcile the payment status. Supports same-day and scheduled debits.\n\nContact Support:\n Name: Efí Pay Developer Support",
      "type": "text/plain"
    }
