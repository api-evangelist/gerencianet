        {
          "info": {
            "name": "Cancel Scheduled Pix",
            "type": "http"
          },
          "http": {
            "method": "PATCH",
            "url": "https://openfinance.api.efipay.com.br/v1/pagamentos-agendados/pix/:identificadorPagamento/cancelar",
            "params": [
              {
                "name": "identificadorPagamento",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Cancel Scheduled Pix"
        },
        {
          "info": {
            "name": "Refund Scheduled Pix",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://openfinance.api.efipay.com.br/v1/pagamentos-agendados/pix/:identificadorPagamento/devolver",
            "params": [
              {
                "name": "identificadorPagamento",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Refund Scheduled Pix"
        }
      ]
