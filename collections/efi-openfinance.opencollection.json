{
  "opencollection": "1.0.0",
  "info": {
    "name": "Efí Pay Open Finance API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "oauth2",
      "flow": "client_credentials",
      "accessTokenUrl": "https://openfinance.api.efipay.com.br/v1/oauth/token",
      "credentials": {
        "clientId": "{{clientId}}",
        "clientSecret": "{{clientSecret}}"
      }
    }
  },
  "items": [
    {
      "info": {
        "name": "Authorization",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Issue Open Finance Token",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://openfinance.api.efipay.com.br/v1/oauth/token"
          },
          "docs": "Issue Open Finance Token"
        }
      ]
    },
    {
      "info": {
        "name": "Participants",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Open Finance Participants",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://openfinance.api.efipay.com.br/v1/participantes/"
          },
          "docs": "List Open Finance Participants"
        }
      ]
    },
    {
      "info": {
        "name": "Configuration",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get Open Finance Config",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://openfinance.api.efipay.com.br/v1/config"
          },
          "docs": "Get Open Finance Config"
        },
        {
          "info": {
            "name": "Update Open Finance Config",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://openfinance.api.efipay.com.br/v1/config"
          },
          "docs": "Update Open Finance Config"
        }
      ]
    },
    {
      "info": {
        "name": "Immediate Pix",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Pix Payments",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://openfinance.api.efipay.com.br/v1/pagamentos/pix"
          },
          "docs": "List Pix Payments"
        },
        {
          "info": {
            "name": "Start Pix Payment",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://openfinance.api.efipay.com.br/v1/pagamentos/pix"
          },
          "docs": "Start Pix Payment"
        },
        {
          "info": {
            "name": "Refund Pix Payment",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://openfinance.api.efipay.com.br/v1/pagamentos/pix/:identificadorPagamento/devolver",
            "params": [
              {
                "name": "identificadorPagamento",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Refund Pix Payment"
        }
      ]
    },
    {
      "info": {
        "name": "Scheduled Pix",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Scheduled Pix",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://openfinance.api.efipay.com.br/v1/pagamentos-agendados/pix"
