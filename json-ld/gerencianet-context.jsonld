{
  "@context": {
    "@version": 1.1,
    "schema": "https://schema.org/",
    "efi": "https://api-evangelist.github.io/gerencianet/vocab#",
    "fibo": "https://spec.edmcouncil.org/fibo/ontology/",
    "bcb": "https://www.bcb.gov.br/pix#",
    "Charge": "efi:Charge",
    "PixCob": "efi:PixCob",
    "PixCobV": "efi:PixCobV",
    "PixReceived": "efi:PixReceived",
    "PixSend": "efi:PixSend",
    "Subscription": "efi:Subscription",
    "Plan": "efi:Plan",
    "Carnet": "efi:Carnet",
    "PaymentLink": "efi:PaymentLink",
    "SplitConfig": "efi:SplitConfig",
    "Account": "efi:Account",
    "BillPayment": "efi:BillPayment",
    "txid": { "@id": "efi:txid" },
    "endToEndId": { "@id": "efi:endToEndId" },
    "chave": { "@id": "efi:pixKey" },
    "valor": { "@id": "schema:price" },
    "status": { "@id": "schema:orderStatus" },
    "criacao": { "@id": "schema:dateCreated", "@type": "schema:DateTime" },
    "horario": { "@id": "schema:dateTime", "@type": "schema:DateTime" },
    "cpf": { "@id": "efi:cpf" },
    "cnpj": { "@id": "efi:cnpj" },
    "nome": { "@id": "schema:name" },
    "items": { "@id": "schema:itemListElement", "@container": "@list" },
    "marketplace": { "@id": "efi:marketplaceSplit" },
    "repasses": { "@id": "efi:splitPayee", "@container": "@list" },
    "payee_code": { "@id": "efi:payeeCode" },
    "notification_url": { "@id": "schema:url", "@type": "@id" }
  }
}
